# 주어진 파일 이름의 모든 심볼릭 링크(symlink)를 재귀적으로 따라가며 실제 경로를 찾음
canonicalize() {
    NAME="$1"
    if [ -f "$NAME" ]
    then
        DIR=$(dirname -- "$NAME")
        NAME=$(cd -P "$DIR" > /dev/null && pwd -P)/$(basename -- "$NAME")
    fi
    while [ -h "$NAME" ]; do
        DIR=$(dirname -- "$NAME")
        SYM=$(readlink "$NAME")
        NAME=$(cd "$DIR" > /dev/null && cd "$(dirname -- "$SYM")" > /dev/null && pwd)/$(basename -- "$SYM")
    done
    echo "$NAME"
}

# CLI 환경에서 사용할 PHP 실행 파일을 찾음
findCliPhp() {
    for TESTEXEC in php php-cli /usr/local/bin/php
    do
        SAPI=$(echo "<?= PHP_SAPI ?>" | $TESTEXEC 2>/dev/null)
        if [ "$SAPI" = "cli" ]
        then
            echo $TESTEXEC
            return
        fi
    done
    echo "Failed to find a CLI version of PHP; falling back to system standard php executable" >&2
    echo "php";
}

# 현재 경로가 심볼릭 링크인 경우 실제 경로를 확인
realname="$0"
if [ -L "$realname" ] 
then
	realname=$(readlink -f "$0")
fi

CONSOLE=$(dirname -- "$(canonicalize "$realname")")
APP=$(dirname "$CONSOLE")

# CLI 환경에서 사용할 PHP 실행 파일 경로를 정의
# 실행된 파일이 'cake'가 아닐 경우 해당 파일을 CakePHP 셸로 실행
if [ -z "$PHP" ]
then
    PHP=$(findCliPhp)
fi

if [ "$(basename "$realname")" != 'cake' ]
then
    exec "$PHP" "$CONSOLE"/cake.php "$(basename "$realname")" "$@"
else
    exec "$PHP" "$CONSOLE"/cake.php "$@"
fi

exit
